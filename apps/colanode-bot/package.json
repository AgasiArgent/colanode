{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@colanode/bot",
  "version": "1.0.0",
  "private": true,
  "description": "Colanode @claude bot — headless mention-reply daemon",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "tsx src/index.ts",
    "provision": "tsx src/provision.ts",
    "lint": "eslint --ext .ts src",
    "test": "vitest run",
    "triage:project": "tsx src/triage-project.ts",
    "triage:linear": "tsx src/linear/run.ts",
    "triage:codex-fix": "tsx src/codex-fix/run.ts"
  },
  "dependencies": {
    "@colanode/agent-tools": "*",
    "@colanode/client": "*",
    "@colanode/client-node": "*",
    "@colanode/core": "*"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
