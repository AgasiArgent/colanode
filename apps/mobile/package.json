{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "@colanode/mobile",
  "version": "1.0.0",
  "author": "Colanode",
  "description": "Colanode mobile application",
  "main": "src/index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
