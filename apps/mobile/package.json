    "compile": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@expo-google-fonts/bricolage-grotesque": "^0.4.1",
    "@expo-google-fonts/karla": "^0.4.2",
    "@expo-google-fonts/spline-sans-mono": "^0.4.2",
    "@react-navigation/bottom-tabs": "^7.18.8",
    "@react-navigation/native": "^7.3.8",
    "@react-navigation/native-stack": "^7.17.10",
    "@tanstack/react-db": "^0.1.79",
    "@tanstack/react-query": "^5.101.2",
    "expo": "~54.0.35",
    "expo-asset": "^12.0.12",
    "expo-clipboard": "~8.0.8",
    "expo-crypto": "~15.0.9",
    "expo-device": "~8.0.10",
    "expo-file-system": "^19.0.21",
    "expo-font": "~14.0.12",
    "expo-notifications": "~0.32.0",
    "expo-random": "^14.0.1",
