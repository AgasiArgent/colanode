    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "~19.1.10",
    "@types/react-dom": "~19.1.7",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-preset-expo": "^54.0.10",
    "typescript": "~5.9.3",
