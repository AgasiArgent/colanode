{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "MCP",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@colanode/mcp/*": ["src/*"],
      "@colanode/client-node": ["../../packages/client-node/src/index.ts"],
      "@colanode/client-node/*": ["../../packages/client-node/src/*"],
      "@colanode/core/*": ["../../packages/core/src/*"],
      "@colanode/crdt/*": ["../../packages/crdt/src/*"],
      "@colanode/client/*": ["../../packages/client/src/*"]
    }
  },
  "references": [
    { "path": "../../packages/core/tsconfig.json" },
    { "path": "../../packages/crdt/tsconfig.json" },
    { "path": "../../packages/client/tsconfig.json" }
  ],
  "include": ["src/**/*.ts"]
}
